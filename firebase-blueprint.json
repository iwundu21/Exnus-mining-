{
  "entities": {
    "User": {
      "title": "User",
      "description": "Mining user data",
      "type": "object",
      "properties": {
        "wallet": { "type": "string" },
        "hashpower": { "type": "number" },
        "totalEarned": { "type": "number" },
        "rewardDebt": { "type": "number" },
        "lastReward": { "type": "number" }
      },
      "required": ["wallet", "hashpower", "totalEarned", "rewardDebt"]
    },
    "Block": {
      "title": "Block",
      "description": "Mining block history",
      "type": "object",
      "properties": {
        "blockNumber": { "type": "number" },
        "timestamp": { "type": "number" },
        "reward": { "type": "number" },
        "totalHashpower": { "type": "number" }
      },
      "required": ["blockNumber", "timestamp", "reward", "totalHashpower"]
    }
  },
  "firestore": {
    "/users/{wallet}": {
      "schema": "User",
      "description": "User mining profiles"
    },
    "/history/{blockNumber}": {
      "schema": "Block",
      "description": "Mining block history"
    },
    "/system/state": {
      "schema": {
        "type": "object",
        "properties": {
          "lastProcessedBlock": { "type": "number" },
          "accRewardPerShare": { "type": "number" },
          "totalHashpower": { "type": "number" },
          "totalDistributed": { "type": "number" }
        }
      },
      "description": "Global engine state"
    }
  }
}
