{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user mining data and total earnings.",
      "type": "object",
      "properties": {
        "wallet": { "type": "string", "description": "Solana wallet address" },
        "hashpower": { "type": "number", "description": "Current mining power in TH/s" },
        "totalEarned": { "type": "number", "description": "Total EXN rewards earned" },
        "lastReward": { "type": "number", "description": "Amount from the last block reward" }
      },
      "required": ["wallet", "hashpower", "totalEarned"]
    },
    "MiningRecord": {
      "title": "Mining Record",
      "description": "A single block reward distribution record for a user.",
      "type": "object",
      "properties": {
        "blockNumber": { "type": "number" },
        "reward": { "type": "number" },
        "timestamp": { "type": "number" },
        "hashpower": { "type": "number" }
      },
      "required": ["blockNumber", "reward", "timestamp", "hashpower"]
    },
    "NetworkStatus": {
      "title": "Network Status",
      "description": "Global state of the mining network.",
      "type": "object",
      "properties": {
        "currentBlock": { "type": "number" },
        "lastBlockTimestamp": { "type": "number" },
        "totalDistributed": { "type": "number" }
      },
      "required": ["currentBlock", "lastBlockTimestamp", "totalDistributed"]
    }
  },
  "firestore": {
    "/users/{wallet}": {
      "schema": "User",
      "description": "User profiles indexed by wallet address"
    },
    "/users/{wallet}/history/{blockId}": {
      "schema": "MiningRecord",
      "description": "Per-user mining history"
    },
    "/status/global": {
      "schema": "NetworkStatus",
      "description": "Global network state"
    }
  }
}
