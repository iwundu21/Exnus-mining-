rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {wallet}
    // Fields:
    //   - wallet: string (required)
    //   - hashpower: number (required)
    //   - totalEarned: number (required)
    //   - lastReward: number (optional)
    //
    // Collection: users/{wallet}/history
    // Document ID: {blockId}
    // Fields:
    //   - blockNumber: number
    //   - reward: number
    //   - timestamp: number
    //   - hashpower: number
    //
    // Collection: status
    // Document ID: global
    // Fields:
    //   - currentBlock: number
    //   - lastBlockTimestamp: number
    //   - totalDistributed: number
    //
    // Collection: history
    // Document ID: {auto-id}
    // Fields:
    //   - blockNumber: number
    //   - timestamp: number
    //   - reward: number
    //   - totalHashpower: number
    //   - activeMiners: number
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mikeebube14@gmail.com" && request.auth.token.email_verified == true));
    }

    // Rules
    match /users/{wallet} {
      allow read, write: if true;
      
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    match /status/{document=**} {
      allow read, write: if true;
    }

    match /history/{blockId} {
      allow read, write: if true;
      
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }
  }
}
