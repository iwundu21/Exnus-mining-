rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(wallet) {
      return true; // Simplified for Solana wallet-based app
    }

    match /users/{wallet} {
      allow read: if true;
      allow write: if true; // In a production app, this should be restricted to server-side or authenticated users.
    }

    match /history/{blockId} {
      allow read: if true;
      allow write: if true; // Temporary for prototype server access
    }

    match /system/state {
      allow read: if true;
      allow write: if true; // Temporary for prototype server access
    }

    match /signatures/{signature} {
      allow read: if false;
      allow write: if true; // In a production app, this should be restricted
    }
  }
}
